# ═══════════════════════════════════════════════════════════════════
#  MLB Data Pipeline — Environment Configuration
#  Copy this file to .env and fill in your PostgreSQL credentials.
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL Connection ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mlb_sabermetrics

# Or override with a full connection string:
# DATABASE_URL=postgresql://user:pass@host:5432/mlb_sabermetrics

# ── Pipeline Settings ───────────────────────────────────────────
# Minimum plate appearances for batters (default: 50)
MIN_PA=50

# Minimum innings pitched for pitchers (default: 20)
MIN_IP=20

# Default season (0 = current year)
DEFAULT_SEASON=0

# Rows per bulk insert batch
BULK_INSERT_CHUNK=500

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
